{
  "extends": ["./tsconfig-nextjs.json", "./tsconfig-vite.json"],
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/client/*"],
      "@App/*": ["./src/app/*"],
      "@lib/*": ["./src/lib/*"],
      "@i18n/*": ["./src/i18n/*"]
    }
  }
}
